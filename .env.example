# Server
PORT=4000
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_CONTENTGRADE_PRO=
STRIPE_PRICE_CONTENTGRADE_BUSINESS=
STRIPE_PRICE_CONTENTGRADE_TEAM=
STRIPE_PRICE_AUDIENCEDECODER=
STRIPE_PRICE_TOKENS=
STRIPE_PRICE_TOKEN_SINGLE=
STRIPE_WEBHOOK_SECRET=

# Turso (persistent database)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Gemini API (powers PageRoast)
GEMINI_API_KEY=

# Anthropic API — Academy proxy (POST /api/academy/ask)
# Keep separate from any other Anthropic key so it can be rotated independently.
# Required in production: server refuses to start without it.
ANTHROPIC_API_KEY_ACADEMY=

# Public URL
PUBLIC_URL=https://bilko.run
