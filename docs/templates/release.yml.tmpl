name: release

# Trigger on semver tag push. For monorepo subpackages, use the per-package
# tag pattern instead (e.g. `agent-trace-v*.*.*`).
on:
  push:
    tags:
      - 'v*.*.*'

jobs:
  release:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      id-token: write   # required for npm provenance attestation

    steps:
      # Pin actions by SHA, not by tag, for supply-chain safety.
      # Replace these SHAs with current pinned versions when copying this template.
      - name: Checkout
        uses: actions/checkout@<TODO-pin-sha>

      - name: Setup Node
        uses: actions/setup-node@<TODO-pin-sha>
        with:
          node-version: 20
          registry-url: https://registry.npmjs.org

      - name: Setup pnpm
        uses: pnpm/action-setup@<TODO-pin-sha>
        with:
          version: 9

      - name: Install
        run: pnpm install --frozen-lockfile

      - name: Build
        run: pnpm build

      - name: Test
        run: pnpm test

      - name: Publish
        run: npm publish --access public --provenance
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_AUTOMATION_TOKEN }}

# Monorepo variant — replace the publish step with:
#
#   - name: Publish (workspace)
#     run: pnpm -r publish --access public --provenance --filter='[HEAD~1]'
#     env:
#       NODE_AUTH_TOKEN: ${{ secrets.NPM_AUTOMATION_TOKEN }}
#
# For Changesets-managed monorepos, use the changesets/action workflow instead:
#   https://github.com/changesets/action
