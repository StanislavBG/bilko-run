name: release

# Trigger on semver tag push. For monorepo subpackages, use the per-package
# tag pattern instead (e.g. `agent-trace-v*.*.*`).
on:
  push:
    tags:
      - 'v*.*.*'

jobs:
  release:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      id-token: write   # required for npm provenance attestation

    steps:
      # SHAs pinned to specific versions for supply-chain safety.
      # Verify and update when bumping action versions.
      - name: Checkout
        uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683  # v4.2.2

      - name: Setup Node
        uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020  # v4.4.0
        with:
          node-version: 20
          registry-url: https://registry.npmjs.org

      - name: Setup pnpm
        uses: pnpm/action-setup@a7487c7e89a18df4991f7f222e4898a00d66ddda  # v4.1.0
        with:
          version: 9

      - name: Install
        run: pnpm install --frozen-lockfile

      - name: Build
        run: pnpm build

      - name: Test
        run: pnpm test

      - name: Publish
        run: npm publish --access public --provenance
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_AUTOMATION_TOKEN }}

# ── Monorepo variant ──────────────────────────────────────────────────────────
# Replace the Publish step above with this for Changesets-managed monorepos:
#
#   - name: Publish (workspace)
#     uses: changesets/action@v1
#     with:
#       publish: pnpm release
#     env:
#       GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
#       NODE_AUTH_TOKEN: ${{ secrets.NPM_AUTOMATION_TOKEN }}
#
# Or for manual filter-based publishing (non-Changesets):
#   run: pnpm -r publish --access public --provenance --filter='[HEAD~1]'
