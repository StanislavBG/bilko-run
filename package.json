{
  "name": "bilko-run",
  "version": "1.0.0",
  "description": "bilko.run — AI tools for makers who ship",
  "type": "module",
  "private": true,
  "files": [
    "dist",
    "dist-server/server",
    "dist-server/shared",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "landing-page",
    "page-roast",
    "conversion",
    "solopreneur",
    "cro",
    "gemini"
  ],
  "homepage": "https://bilko.run",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StanislavBG/bilko-run.git"
  },
  "bugs": {
    "url": "https://github.com/StanislavBG/bilko-run/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "stats": "node scripts/npm-stats.js",
    "stats:week": "node scripts/npm-stats.js --week",
    "metrics": "node scripts/metrics.js",
    "metrics:save": "node scripts/metrics.js --save",
    "metrics:history": "node scripts/metrics.js --history",
    "metrics:csv": "node scripts/metrics.js --csv",
    "github-traffic": "node scripts/github-traffic.js"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.3",
    "@clerk/clerk-react": "^5.61.3",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@libsql/client": "^0.17.2",
    "@mlc-ai/web-llm": "^0.2.82",
    "ajv": "^8.18.0",
    "fastify": "^5.8.2",
    "js-yaml": "^4.1.1",
    "stripe": "^14.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^8.2.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
